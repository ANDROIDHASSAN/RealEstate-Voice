{
  "name": "closeflow",
  "private": true,
  "version": "0.1.0",
  "description": "CloseFlow OS — the operating system real estate agents run their business on.",
  "workspaces": [
    "packages/shared",
    "packages/integrations",
    "services/voice",
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c yellow,cyan \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "npm run dev -w apps/api",
    "dev:web": "npm run dev -w apps/web",
    "build": "npm run build -w packages/shared && npm run build -w packages/integrations && npm run build -w services/voice && npm run build -w apps/api && npm run build -w apps/web",
    "test": "npm run test -w apps/api",
    "e2e": "playwright test --config tests/e2e/playwright.config.ts",
    "load": "node tests/load/lead-webhook.load.mjs",
    "seed": "npm run seed -w apps/api",
    "lint": "eslint apps packages services --ext .ts,.tsx --max-warnings 0",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,css}\""
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "autocannon": "^8.0.0",
    "concurrently": "^9.1.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "prettier": "^3.4.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
