# ---------- CORE APP ----------
NODE_ENV=development
APP_URL=http://localhost:5173
API_URL=http://localhost:4100
PORT=4100
JWT_SECRET=
JWT_REFRESH_SECRET=

# ---------- DATABASE (empty = in-memory Mongo + in-memory queue for local dev) ----------
MONGO_URI=
# Must be redis:// or rediss:// (Upstash "https://…" REST URLs do NOT work with BullMQ)
REDIS_URL=

# ---------- LLM / TEXT AI (fallback chain: Gemini -> Groq -> OpenAI -> mock) ----------
GEMINI_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Provider + model are also selectable in Settings → Integrations (stored per account).
# LLM_PROVIDER: auto | gemini | groq | openai   (auto = first available)
LLM_PROVIDER=auto
GEMINI_MODEL=gemini-2.0-flash
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_MODEL=gpt-4o-mini

# ---------- VOICE AGENTS ----------
GEMINI_LIVE_API_KEY=
ELEVENLABS_API_KEY=
DEEPGRAM_API_KEY=
DOGRAH_BASE_URL=
DOGRAH_API_KEY=
VAPI_API_KEY=
# dograh | gemini-live | vapi | mock (falls back to mock when unconfigured)
VOICE_PROVIDER=mock
# Vapi pipeline pieces — also selectable in Settings → Integrations.
VOICE_TTS_PROVIDER=11labs
VOICE_TTS_VOICE=
VOICE_STT_PROVIDER=deepgram
VOICE_LLM_PROVIDER=groq
VOICE_LLM_MODEL=llama-3.3-70b-versatile
# ---------- VIDEO ----------
# VIDEO_PROVIDER: creatomate | higgsfield
VIDEO_PROVIDER=creatomate
# Test/dev switches
FORCE_MOCK_PROVIDERS=
COMPLIANCE_IGNORE_QUIET_HOURS=
MOCK_CALL_DELAY_MS=

# ---------- TELEPHONY ----------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ---------- WHATSAPP ----------
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_BUSINESS_ID=
WHATSAPP_VERIFY_TOKEN=

# ---------- EMAIL ----------
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ---------- INSTAGRAM (pending Meta App Review) ----------
IG_APP_ID=
IG_APP_SECRET=
IG_ACCESS_TOKEN=

# ---------- LEAD SCRAPING ----------
APIFY_TOKEN=

# ---------- CRM (optional) ----------
GHL_CLIENT_ID=
GHL_CLIENT_SECRET=

# ---------- BILLING ----------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ---------- VIDEO / CONTENT (stub until keyed) ----------
HIGGSFIELD_API_KEY=
CREATOMATE_API_KEY=

# ---------- MULTI-AGENT SERVICE ----------
AGENTS_SERVICE_URL=http://localhost:8000

# ---------- DEMO ----------
# Set to 1 on the deployed demo to enable POST /auth/seed-demo in production
ALLOW_DEMO_SEED=

# ---------- i18n ----------
DEFAULT_LOCALE=en
SUPPORTED_LOCALES=en,es,ar,pt,ht
